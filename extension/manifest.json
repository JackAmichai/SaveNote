{
  "manifest_version": 3,
  "name": "SaveNote — WhatsApp Memory Assistant",
  "version": "1.0.0",
  "description": "Save and organize notes directly from WhatsApp Web. AI-powered categorization with instant recall.",
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
